                <div class="material-grid">
                  <div 
                    v-for="(m, idx) in recipe" 
                    :key="idx" 
                    :class="['material-item', 'glass-panel', { 'is-clickable': m.isCraftable || (m.sources && m.sources.length > 0) }]"
                    @click="handleMaterialClick(m)"
