                      </div>
                    </div>
                    
                    <!-- Sources Section -->
                    <div v-if="m.sources && m.sources.length > 0" class="mat-sources">
                      <div v-for="(src, sidx) in m.sources" :key="sidx" class="source-tag">
                        <ShoppingCart v-if="src.type === 'shop'" :size="12" />
                        <Target v-else-if="src.type === 'drop'" :size="12" />
                        <Pickaxe v-else-if="src.type === 'gather'" :size="12" />
                        <Fish v-else-if="src.type === 'fish'" :size="12" />
                        <span class="source-text">
                          <template v-if="src.type === 'shop'">
